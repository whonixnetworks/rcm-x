show_help() {
    show_header "rcmv v${VERSION}"

    ui "${CYAN}Usage:${NC} ${WHITE}rcmv [COMMAND] [OPTIONS]${NC}"
    ui "${DIM}Upload local media to a rclone crypt remote with fast parallel transfers.${NC}"
    ui

    show_section "Commands"
