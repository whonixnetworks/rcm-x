    ui "  rcmv --run --force              ${DIM}# replace cloud duplicates with local${NC}"
    ui "  rcmv --run --delete-after       ${DIM}# free local space after upload${NC}"
    ui "  rcmv --run --background         ${DIM}# silent, for cron${NC}"
    ui "  rcmv --bwlimit 5M"
    ui "  rcmv --logs --errors"
    ui "  rcmv --logs --tail"
    ui "  rcmv --cron                     ${DIM}# manage cron schedule${NC}"
    ui
}

# ── Initialise ───────────────────────────────────────────────────────────────────
mkdir -p "$(dirname "$LOG_FILE")" "$(dirname "$CONFIG_FILE")"

# ── Pre-parse: scan all args before dispatch ──────────────────────────────────────
_FORCE_ARG=false
_DELETE_AFTER_ARG=false
for _a in "$@"; do
    case "$_a" in
        --force)        _FORCE_ARG=true ;;
        --delete-after) _DELETE_AFTER_ARG=true ;;
        --background)   BACKGROUND=true ;;
    esac
done

# Re-apply terminal/color state after BACKGROUND is resolved
if $BACKGROUND; then
    TERMINAL=false
    RED='' GREEN='' YELLOW='' BLUE='' CYAN='' MAGENTA=''
    WHITE='' GRAY='' BOLD='' DIM='' NC=''
fi

load_config

# CLI flags always win over saved config
$_FORCE_ARG        && FORCE_OVERWRITE="true"
$_DELETE_AFTER_ARG && DELETE_AFTER_UPLOAD="true"

# Warn if unconfigured (skip for bootstrap commands)
_NO_WARN=(--setup --install --uninstall -h --help -v --version --doctor)
_warn=true
for _a in "${_NO_WARN[@]}"; do
    [[ "${1:-}" == "$_a" ]] && _warn=false && break
done
if $_warn && [[ -z "$SOURCE_DIR" || -z "$REMOTE" ]]; then
    $BACKGROUND || {
        echo -e "${YELLOW}⚠ rcmv not configured. Run: rcmv --setup${NC}"
        echo
    }
fi

# ── Argument Dispatch ─────────────────────────────────────────────────────────────
case "${1:-}" in
    --run)
        run_upload "$FORCE_OVERWRITE"
        ;;
    --dry-run)
        run_dry "$FORCE_OVERWRITE"
        ;;
    --status|-s)
        show_status
        ;;
    --setup|--init)
        setup_wizard
        ;;
    --cron)
        manage_cron
        ;;
    --install)
        install_script
        ;;
    --uninstall)
        uninstall_script
        ;;
    --doctor)
        check_dependencies
        ;;
    --save-config)
        save_config
        ;;
    -h|--help)
        show_help
        ;;
    -v|--version)
        echo "rcmv v${VERSION}"
        ;;
    --bwlimit|--bw)
        [[ $# -ge 2 ]] || die "--bwlimit requires an argument (e.g. 10M, off)"
        set_bandwidth "$2"
        ;;
    --logs|-l)
        shift
        _mode="tail" _lines="50"
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --tail|--follow|-t) _mode="--tail" ;;
                --errors|-e)        _mode="--errors" ;;
                --full)             _mode="--full" ;;
                [0-9]*)             _lines="$1" ;;
                *)                  break ;;
            esac
            shift
        done
        view_logs "$_mode" "$_lines"
        ;;
    --force|--delete-after|--background)
        log_error "'$1' is a modifier flag, not a command."
        echo "  Usage: rcmv --run $1"
        echo "  Try 'rcmv --help' for full usage."
        exit 1
        ;;
    "")
        show_help
        ;;
    *)
        log_error "Unknown option: $1"
        echo "Try 'rcmv --help' for available options."
        exit 1
        ;;
esac
