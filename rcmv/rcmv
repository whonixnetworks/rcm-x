    ui "  ${WHITE}--run --force${NC}             Upload all, replacing cloud files with local"
    ui "  ${WHITE}--dry-run${NC}                 Preview what would be uploaded (no transfer)"
    ui "  ${WHITE}--dry-run --force${NC}         Preview a force-overwrite run"
    ui "  ${WHITE}--status${NC}                  Show config, source info, and remote check"
    ui "  ${WHITE}--setup${NC}                   Interactive configuration wizard"
    ui "  ${WHITE}--cron${NC}                    Manage cron schedule"
    ui "  ${WHITE}--install${NC}                 Copy to ${INSTALL_PATH} + add shell alias"
    ui "  ${WHITE}--uninstall${NC}               Remove binary, alias, and cron entries"
    ui "  ${WHITE}--doctor${NC}                  Check dependencies and connectivity"
    ui

    show_section "Options"
    ui "  ${WHITE}--force${NC}                   Replace cloud files with local (use with --run or --dry-run)"
    ui "  ${WHITE}--delete-after${NC}            Use rclone move — delete local files after confirmed upload"
    ui "  ${WHITE}--background${NC}              Suppress all terminal output (for cron/automation)"
    ui "  ${WHITE}--bwlimit [SPEED]${NC}         Set bandwidth cap (e.g. 10M, 512K, off)"
    ui "  ${WHITE}--logs [MODE] [N]${NC}         View upload logs"
    ui "       Modes: ${DIM}--tail/-t (follow live), --errors/-e, --full${NC}"
    ui "       Example: ${DIM}rcmv --logs --errors 100${NC}"
    ui "  ${WHITE}-h, --help${NC}                Show this help"
    ui "  ${WHITE}-v, --version${NC}             Show version"
    ui

    show_section "Cron / Background Usage"
    ui "  ${DIM}--background silences all terminal output and skips the confirmation${NC}"
    ui "  ${DIM}prompt. Rclone logs are always written to the log file regardless.${NC}"
    ui "  ${DIM}Notifications are sent even in background mode.${NC}"
    ui
    ui "  ${DIM}Example crontab (run at 2am daily):${NC}"
    ui "  ${WHITE}  0 2 * * * ${INSTALL_PATH} --run --background${NC}"
    ui "  ${DIM}Example with move mode (free local space):${NC}"
    ui "  ${WHITE}  0 2 * * * ${INSTALL_PATH} --run --delete-after --background${NC}"
    ui "  ${DIM}Manage your schedule interactively:${NC}  ${WHITE}rcmv --cron${NC}"
    ui

    show_section "Current Configuration"
    ui "  Source:         ${WHITE}${SOURCE_DIR:-<not set>}${NC}"
    ui "  Destination:    ${WHITE}${REMOTE:-<not set>}:${REMOTE_PATH}${NC}"
    ui "  Transfers:      ${WHITE}${TRANSFERS}${NC}"
    ui "  Checkers:       ${WHITE}${CHECKERS}${NC}"
    ui "  Buffer:         ${WHITE}${BUFFER_SIZE}${NC}"
    ui "  Chunk:          ${WHITE}${CHUNK_SIZE}${NC}"
