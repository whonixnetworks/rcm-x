#!/usr/bin/env bash
# rcmv — Rclone media upload manager with crypt remote support
# author: greedy
# version: 1.2.0
# license: MIT

set -uo pipefail

# ── Constants ───────────────────────────────────────────────────────────────────
readonly VERSION="1.2.0"
readonly CONFIG_FILE="$HOME/.config/rcmv/config.conf"
readonly LOG_FILE="$HOME/.local/share/rcmv/upload.log"
readonly SCRIPT_NAME="rcmv"
readonly INSTALL_PATH="/usr/local/bin/${SCRIPT_NAME}"

# ── Runtime Defaults (overwritten by load_config) ───────────────────────────────
SOURCE_DIR=""
REMOTE=""
REMOTE_PATH=""
TRANSFERS=16
CHECKERS=32
MULTI_THREAD_STREAMS=4
BUFFER_SIZE="256M"
CHUNK_SIZE="256M"
BWLIMIT=""
FORCE_OVERWRITE="false"
DELETE_AFTER_UPLOAD="false"

# Notifications
NOTIFY_PUSHOVER="false"
PUSHOVER_USER_KEY=""
PUSHOVER_APP_TOKEN=""
NOTIFY_NTFY="false"
NTFY_URL=""
NTFY_TOPIC=""

# ── Mode Flags ──────────────────────────────────────────────────────────────────
BACKGROUND=false

# ── Terminal Detection ──────────────────────────────────────────────────────────
[[ -t 1 ]] && TERMINAL=true || TERMINAL=false

# ── Colors ──────────────────────────────────────────────────────────────────────
if $TERMINAL; then
    RED='\033[0;31m'    GREEN='\033[0;32m'  YELLOW='\033[1;33m'
    BLUE='\033[0;34m'   CYAN='\033[0;36m'   MAGENTA='\033[0;35m'
    WHITE='\033[1;37m'  GRAY='\033[0;90m'   BOLD='\033[1m'
    DIM='\033[2m'       NC='\033[0m'
else
    RED='' GREEN='' YELLOW='' BLUE='' CYAN='' MAGENTA=''
    WHITE='' GRAY='' BOLD='' DIM='' NC=''
fi

# ── Logging ─────────────────────────────────────────────────────────────────────
log_info()    { $BACKGROUND || echo -e "${BLUE}[INFO]${NC} $*"; }
log_success() { $BACKGROUND || echo -e "${GREEN}[✓]${NC} $*"; }
log_warning() { $BACKGROUND || echo -e "${YELLOW}[WARNING]${NC} $*"; }
log_error()   { echo -e "${RED}[ERROR]${NC} $*" >&2; }
die()         { log_error "$*"; exit 1; }

# Background-safe print: suppressed when --background is active
ui() { $BACKGROUND || echo -e "$*"; }

# ── UI Helpers ──────────────────────────────────────────────────────────────────
show_header() {
    ui
    ui "${BLUE}========================================${NC}"
    ui "${BLUE}   $*${NC}"
    ui "${BLUE}========================================${NC}"
    ui
}

show_section() { ui "${MAGENTA}=== $* ===${NC}"; }

box() {
    local color="${1:-$MAGENTA}" title="$2"
    ui "${color}╭─────────────────────────────────────╮${NC}"
    $BACKGROUND || printf "${color}│${NC}   ${BOLD}${color}%-33s${NC}${color}│${NC}\n" "$title"
    ui "${color}╰─────────────────────────────────────╯${NC}"
    ui
}

result_box() {
    local ok="$1"
    local msg_ok="${2:-Success}" msg_fail="${3:-Failed}"
    if [[ "$ok" == true ]]; then
        ui "${BOLD}${GREEN}╭─────────────────────────────────────╮${NC}"
        $BACKGROUND || printf "${BOLD}${GREEN}│${NC}   ${GREEN}✓ %-32s${BOLD}${GREEN}│${NC}\n" "$msg_ok"
        ui "${BOLD}${GREEN}╰─────────────────────────────────────╯${NC}"
    else
        ui "${BOLD}${RED}╭─────────────────────────────────────╮${NC}"
        $BACKGROUND || printf "${BOLD}${RED}│${NC}   ${RED}✗ %-32s${BOLD}${RED}│${NC}\n" "$msg_fail"
        ui "${BOLD}${RED}╰─────────────────────────────────────╯${NC}"
    fi
}

press_any_key() {
    ui "${DIM}Press any key to continue...${NC}"
    read -r -s -n1
}

# ── Configuration ────────────────────────────────────────────────────────────────
load_config() {
    [[ ! -f "$CONFIG_FILE" ]] && return 0
    local line key value
    while IFS= read -r line; do
        [[ "$line" =~ ^[[:space:]]*# ]] && continue
        [[ -z "${line// }" ]]           && continue
        if [[ "$line" =~ ^(SOURCE_DIR|REMOTE|REMOTE_PATH|TRANSFERS|CHECKERS|MULTI_THREAD_STREAMS|BUFFER_SIZE|CHUNK_SIZE|BWLIMIT|FORCE_OVERWRITE|DELETE_AFTER_UPLOAD|NOTIFY_PUSHOVER|PUSHOVER_USER_KEY|PUSHOVER_APP_TOKEN|NOTIFY_NTFY|NTFY_URL|NTFY_TOPIC)=(.*)$ ]]; then
            key="${BASH_REMATCH[1]}"
            value="${BASH_REMATCH[2]}"
            value="${value%\"}"
            value="${value#\"}"
            printf -v "$key" '%s' "$value"
        fi
    done < "$CONFIG_FILE"
}

save_config() {
    mkdir -p "$(dirname "$CONFIG_FILE")"
    cat > "$CONFIG_FILE" << EOF
# rcmv configuration — generated by rcmv v${VERSION}
# Edit manually or re-run: rcmv --setup

SOURCE_DIR="${SOURCE_DIR}"
REMOTE="${REMOTE}"
REMOTE_PATH="${REMOTE_PATH}"
TRANSFERS=${TRANSFERS}
CHECKERS=${CHECKERS}
MULTI_THREAD_STREAMS=${MULTI_THREAD_STREAMS}
BUFFER_SIZE="${BUFFER_SIZE}"
CHUNK_SIZE="${CHUNK_SIZE}"
BWLIMIT="${BWLIMIT}"
FORCE_OVERWRITE="${FORCE_OVERWRITE}"
DELETE_AFTER_UPLOAD="${DELETE_AFTER_UPLOAD}"

# Notifications
NOTIFY_PUSHOVER="${NOTIFY_PUSHOVER}"
PUSHOVER_USER_KEY="${PUSHOVER_USER_KEY}"
PUSHOVER_APP_TOKEN="${PUSHOVER_APP_TOKEN}"
NOTIFY_NTFY="${NOTIFY_NTFY}"
NTFY_URL="${NTFY_URL}"
NTFY_TOPIC="${NTFY_TOPIC}"
EOF
    log_success "Configuration saved to ${CONFIG_FILE}"
}

# ── Dependencies ─────────────────────────────────────────────────────────────────
check_dependencies() {
    $BACKGROUND && return 0

    box "$CYAN" "Checking Dependencies"

    local missing=() all_ok=true

    for cmd in rclone curl; do
        if command -v "$cmd" &>/dev/null; then
            ui "  ${GREEN}✓${NC} ${cmd}"
        else
            ui "  ${RED}✗${NC} ${cmd} ${DIM}(not found)${NC}"
            missing+=("$cmd")
            all_ok=false
        fi
    done

    ui
    if [[ ${#missing[@]} -gt 0 ]]; then
        log_error "Missing dependencies: ${missing[*]}"
        ui "${YELLOW}Install with:${NC}"
        ui "  ${WHITE}# Debian/Ubuntu:${NC}  sudo apt install rclone curl"
        ui "  ${WHITE}# Arch:${NC}           sudo pacman -S rclone curl"
        ui "  ${WHITE}# macOS:${NC}          brew install rclone curl"
        ui "  ${WHITE}# Manual:${NC}         https://rclone.org/install/"
        return 1
    fi

    local rclone_conf="$HOME/.config/rclone/rclone.conf"
    if [[ -f "$rclone_conf" ]]; then
        ui "  ${GREEN}✓${NC} rclone config found"
    else
        ui "  ${YELLOW}⚠${NC} No rclone config found at ${rclone_conf}"
        ui "  ${DIM}Run: ${WHITE}rclone config${NC}"
        all_ok=false
    fi

    ui
    if $all_ok; then
        result_box true "All dependencies satisfied"
    else
        result_box false "Some checks failed"
    fi
    return 0
}

# ── Remote Picker ────────────────────────────────────────────────────────────────
# Result is written to _PICKED_REMOTE (global) to avoid subshell stdout-capture
# swallowing all ui() output. Never call this inside $().
_PICKED_REMOTE=""
pick_remote() {
    local prompt_label="$1"
    local rclone_conf="$HOME/.config/rclone/rclone.conf"
    local -a remotes=()

    if [[ -f "$rclone_conf" ]]; then
        while IFS= read -r line; do
            if [[ "$line" =~ ^\[(.+)\]$ ]]; then
                remotes+=("${BASH_REMATCH[1]}")
            fi
        done < "$rclone_conf"
    fi

    if [[ ${#remotes[@]} -eq 0 ]]; then
        ui "  ${YELLOW}⚠${NC} No remotes found in rclone config."
        ui "  ${DIM}Run ${WHITE}rclone config${NC}${DIM} in another terminal to add one, then re-run setup.${NC}"
        echo -ne "  ${BOLD}${prompt_label}${NC} ${DIM}(type name manually): ${NC}"
        read -r _PICKED_REMOTE
        return
    fi

    ui "  ${DIM}Available remotes:${NC}"
    local i=1
    for r in "${remotes[@]}"; do
        ui "    ${WHITE}[${i}]${NC} ${r}"
        (( i++ ))
    done
    ui

    local choice
    while true; do
        echo -ne "  ${BOLD}${prompt_label}${NC} ${DIM}[1-${#remotes[@]}] or type name: ${NC}"
        read -r choice
        if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#remotes[@]} )); then
            _PICKED_REMOTE="${remotes[$((choice - 1))]}"
            break
        elif [[ -n "$choice" ]]; then
            _PICKED_REMOTE="$choice"
            break
        fi
        ui "  ${RED}Invalid selection. Try again.${NC}"
    done
}

# ── Setup Wizard ─────────────────────────────────────────────────────────────────
setup_wizard() {
    show_header "rcmv v${VERSION} — Setup Wizard"
    ui "${CYAN}Welcome to rcmv!${NC} Let's configure your upload settings."
    ui "${DIM}Press Enter to accept defaults shown in brackets.${NC}"
    ui

    check_dependencies || true
    ui

    # ── Source ──────────────────────────────────────────────────────────────────
    show_section "Source Directory"
    ui
    local default_src="${SOURCE_DIR:-$HOME/media}"
    echo -ne "  ${BOLD}Local media path${NC} ${DIM}[${default_src}]: ${NC}"
    read -r input
    SOURCE_DIR="${input:-$default_src}"
    SOURCE_DIR="${SOURCE_DIR%/}"

    if [[ ! -d "$SOURCE_DIR" ]]; then
        ui "  ${YELLOW}⚠${NC} Directory not found: ${WHITE}${SOURCE_DIR}${NC}"
        ui "  ${DIM}It will be validated again before each upload.${NC}"
    else
        ui "  ${GREEN}✓${NC} Found: ${WHITE}${SOURCE_DIR}${NC}"
    fi
    ui

    # ── Remote ──────────────────────────────────────────────────────────────────
    show_section "Rclone Remote"
    ui
    pick_remote "Upload remote"
    REMOTE="$_PICKED_REMOTE"

    ui
    echo -ne "  ${BOLD}Remote path${NC} ${DIM}[${REMOTE_PATH:-media}]: ${NC}"
    read -r input
    REMOTE_PATH="${input:-${REMOTE_PATH:-media}}"
    REMOTE_PATH="${REMOTE_PATH#/}"
    REMOTE_PATH="${REMOTE_PATH%/}"
    ui

    # ── Transfer Tuning ──────────────────────────────────────────────────────────
    show_section "Transfer Tuning"
    ui
    ui "  ${DIM}Defaults are optimised for fast NVMe → Google Drive via crypt.${NC}"
    ui "  ${DIM}Press Enter to keep each default.${NC}"
    ui

    echo -ne "  ${BOLD}Parallel transfers${NC} ${DIM}[${TRANSFERS}]: ${NC}"
    read -r input; TRANSFERS="${input:-$TRANSFERS}"

    echo -ne "  ${BOLD}Parallel checkers${NC}  ${DIM}[${CHECKERS}]: ${NC}"
    read -r input; CHECKERS="${input:-$CHECKERS}"

    echo -ne "  ${BOLD}Buffer size${NC}        ${DIM}[${BUFFER_SIZE}]: ${NC}"
    read -r input; BUFFER_SIZE="${input:-$BUFFER_SIZE}"

    echo -ne "  ${BOLD}Drive chunk size${NC}   ${DIM}[${CHUNK_SIZE}]: ${NC}"
    read -r input; CHUNK_SIZE="${input:-$CHUNK_SIZE}"

    echo -ne "  ${BOLD}Bandwidth limit${NC}    ${DIM}[${BWLIMIT:-unlimited}]: ${NC}"
    read -r input
    if [[ -n "$input" && "$input" != "unlimited" ]]; then
        BWLIMIT="$input"
    else
        BWLIMIT=""
    fi
    ui

    # ── Duplicate Handling ───────────────────────────────────────────────────────
    show_section "Duplicate Handling"
    ui
    ui "  ${DIM}rcmv uploads files from your local directory to the remote.${NC}"
    ui "  ${DIM}If a file already exists on the remote with a matching checksum,${NC}"
    ui "  ${DIM}it is skipped — your cloud copy is left untouched.${NC}"
    ui
    ui "  ${DIM}Force overwrite is for editing workflows where local changes need${NC}"
    ui "  ${DIM}to be pushed to the remote. For a typical media backup workflow${NC}"
    ui "  ${DIM}where you upload-then-delete locally, leave this OFF.${NC}"
    ui
    echo -ne "  ${BOLD}Force overwrite duplicates?${NC} ${DIM}(leave OFF for normal use)${NC} [y/N]: "
    read -r input
    if [[ "${input:-n}" =~ ^[Yy]$ ]]; then
        FORCE_OVERWRITE="true"
        ui "  ${YELLOW}⚠${NC} Force overwrite enabled"
    else
        FORCE_OVERWRITE="false"
        ui "  ${GREEN}✓${NC} Safe mode — existing remote files will not be overwritten"
    fi
    ui

    # ── Delete After Upload ──────────────────────────────────────────────────────
    show_section "Delete After Upload (Move Mode)"
    ui
    ui "  ${RED}${BOLD}⚠ WARNING — MOVE MODE DELETES LOCAL FILES${NC}"
    ui "  ${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    ui "  ${RED}When enabled, rcmv uses 'rclone move' instead of 'rclone copy'.${NC}"
    ui "  ${RED}Each file is permanently removed from local storage immediately${NC}"
    ui "  ${RED}after rclone confirms it has been uploaded. CANNOT be undone.${NC}"
    ui "  ${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    ui
    ui "  ${GRAY}This is the safest way to free local disk space — rclone handles${NC}"
    ui "  ${GRAY}the delete itself, only removing a file once the remote has it.${NC}"
    ui "  ${GRAY}If the upload is interrupted, no files are deleted.${NC}"
    ui
    echo -ne "  ${RED}${BOLD}Enable move mode (delete local after upload)?${NC} [y/N]: "
    read -r input
    if [[ "${input:-n}" =~ ^[Yy]$ ]]; then
        DELETE_AFTER_UPLOAD="true"
        ui
        ui "  ${RED}${BOLD}⚠ CONFIRMED — rclone move will delete local files after upload.${NC}"
        ui "  ${GRAY}A --dry-run is strongly recommended before your first run.${NC}"
    else
        DELETE_AFTER_UPLOAD="false"
        ui "  ${GREEN}✓${NC} Delete after upload disabled — local files will be kept"
    fi
    ui

    # ── Notifications ────────────────────────────────────────────────────────────
    show_section "Notifications"
    ui
    ui "  ${DIM}Configure push notifications for upload completion reports.${NC}"
    ui "  ${DIM}Supports Pushover and/or ntfy. Both can be enabled together.${NC}"
    ui

    # Pushover
    ui "  ${CYAN}── Pushover ──${NC}"
    echo -ne "  ${BOLD}Enable Pushover notifications?${NC} [y/N]: "
    read -r input
    if [[ "${input:-n}" =~ ^[Yy]$ ]]; then
        NOTIFY_PUSHOVER="true"
        echo -ne "  ${BOLD}Pushover User Key${NC}: "
        read -r PUSHOVER_USER_KEY
        echo -ne "  ${BOLD}Pushover App Token${NC}: "
        read -r PUSHOVER_APP_TOKEN
        if [[ -n "$PUSHOVER_USER_KEY" && -n "$PUSHOVER_APP_TOKEN" ]]; then
            ui "  ${GREEN}✓${NC} Pushover configured"
        else
            ui "  ${YELLOW}⚠${NC} Pushover keys incomplete — notifications may fail"
        fi
    else
        NOTIFY_PUSHOVER="false"
        PUSHOVER_USER_KEY=""
        PUSHOVER_APP_TOKEN=""
        ui "  ${DIM}Pushover disabled${NC}"
    fi
    ui

    # ntfy
    ui "  ${CYAN}── ntfy ──${NC}"
    echo -ne "  ${BOLD}Enable ntfy notifications?${NC} [y/N]: "
    read -r input
    if [[ "${input:-n}" =~ ^[Yy]$ ]]; then
        NOTIFY_NTFY="true"
        echo -ne "  ${BOLD}ntfy server URL${NC} ${DIM}[https://ntfy.sh]: ${NC}"
        read -r input
        NTFY_URL="${input:-https://ntfy.sh}"
        NTFY_URL="${NTFY_URL%/}"
        echo -ne "  ${BOLD}ntfy topic${NC}: "
        read -r NTFY_TOPIC
        if [[ -n "$NTFY_TOPIC" ]]; then
            ui "  ${GREEN}✓${NC} ntfy configured: ${WHITE}${NTFY_URL}/${NTFY_TOPIC}${NC}"
        else
            ui "  ${YELLOW}⚠${NC} ntfy topic not set — notifications may fail"
        fi
    else
        NOTIFY_NTFY="false"
        NTFY_URL=""
        NTFY_TOPIC=""
        ui "  ${DIM}ntfy disabled${NC}"
    fi
    ui

    # ── Cron Schedule ────────────────────────────────────────────────────────────
    show_section "Cron Schedule"
    ui
    ui "  ${DIM}Optionally add rcmv to your crontab for automated uploads.${NC}"
    ui
    echo -ne "  ${BOLD}Set up a cron schedule now?${NC} [y/N]: "
    read -r input
    if [[ "${input:-n}" =~ ^[Yy]$ ]]; then
        setup_cron_wizard
    else
        ui "  ${DIM}Skipped. Run ${WHITE}rcmv --cron${NC}${DIM} at any time to configure.${NC}"
    fi
    ui

    # ── Summary ──────────────────────────────────────────────────────────────────
    show_section "Summary"
    ui
    ui "  ${DIM}Source:           ${NC}${WHITE}${SOURCE_DIR}${NC}"
    ui "  ${DIM}Destination:      ${NC}${WHITE}${REMOTE}:${REMOTE_PATH}${NC}"
    ui "  ${DIM}Transfers:        ${NC}${WHITE}${TRANSFERS}${NC}"
    ui "  ${DIM}Checkers:         ${NC}${WHITE}${CHECKERS}${NC}"
    ui "  ${DIM}Buffer:           ${NC}${WHITE}${BUFFER_SIZE}${NC}"
    ui "  ${DIM}Chunk size:       ${NC}${WHITE}${CHUNK_SIZE}${NC}"
    ui "  ${DIM}Bandwidth limit:  ${NC}${WHITE}${BWLIMIT:-unlimited}${NC}"
    ui "  ${DIM}Force overwrite:  ${NC}${WHITE}${FORCE_OVERWRITE}${NC}"
    ui "  ${DIM}Delete after:     ${NC}${WHITE}${DELETE_AFTER_UPLOAD}${NC}"
    ui "  ${DIM}Pushover:         ${NC}${WHITE}${NOTIFY_PUSHOVER}${NC}"
    ui "  ${DIM}ntfy:             ${NC}${WHITE}${NOTIFY_NTFY}${NC}"
    ui "  ${DIM}Config file:      ${NC}${WHITE}${CONFIG_FILE}${NC}"
    ui "  ${DIM}Log file:         ${NC}${WHITE}${LOG_FILE}${NC}"
    ui

    echo -ne "  ${YELLOW}Save configuration?${NC} [Y/n]: "
    read -r confirm
    if [[ "${confirm:-y}" =~ ^[Nn]$ ]]; then
        ui "${DIM}Setup cancelled. No changes saved.${NC}"
        return 1
    fi

    mkdir -p "$(dirname "$LOG_FILE")"
    save_config

    ui
    ui "${GREEN}✓ Setup complete!${NC}"
    ui
    ui "${CYAN}Next steps:${NC}"
    ui "  ${WHITE}rcmv --status${NC}    Verify config and connectivity"
    ui "  ${WHITE}rcmv --dry-run${NC}   Preview what will be uploaded"
    ui "  ${WHITE}rcmv --run${NC}       Start the upload"
    ui
}

# ── Cron Wizard ───────────────────────────────────────────────────────────────────
setup_cron_wizard() {
    local delete_flag=""
    [[ "$DELETE_AFTER_UPLOAD" == "true" ]] && delete_flag=" --delete-after"
    local bg_flag=" --background"

    ui
    ui "  ${DIM}Select a schedule or enter a custom cron expression:${NC}"
    ui
    ui "    ${WHITE}[1]${NC} Daily at 12:00 AM (midnight)"
    ui "    ${WHITE}[2]${NC} Daily at  3:00 AM"
    ui "    ${WHITE}[3]${NC} Daily at  5:00 AM"
    ui "    ${WHITE}[4]${NC} Daily at 12:00 PM (noon)"
    ui "    ${WHITE}[5]${NC} Every 12 hours (midnight & noon)"
    ui "    ${WHITE}[6]${NC} Weekly — Sunday at 3:00 AM"
    ui "    ${WHITE}[7]${NC} Weekly — Saturday at 12:00 AM"
    ui "    ${WHITE}[8]${NC} Custom cron expression"
    ui "    ${WHITE}[0]${NC} Skip"
    ui

    local choice cron_expr cron_label
    while true; do
        echo -ne "  ${BOLD}Schedule${NC} ${DIM}[0-8]: ${NC}"
        read -r choice
        case "$choice" in
            1) cron_expr="0 0 * * *";   cron_label="Daily at midnight";      break ;;
            2) cron_expr="0 3 * * *";   cron_label="Daily at 3:00 AM";       break ;;
            3) cron_expr="0 5 * * *";   cron_label="Daily at 5:00 AM";       break ;;
            4) cron_expr="0 12 * * *";  cron_label="Daily at noon";          break ;;
            5) cron_expr="0 0,12 * * *"; cron_label="Every 12 hours";        break ;;
            6) cron_expr="0 3 * * 0";   cron_label="Weekly Sunday 3:00 AM";  break ;;
            7) cron_expr="0 0 * * 6";   cron_label="Weekly Saturday midnight"; break ;;
            8)
                echo -ne "  ${BOLD}Custom cron expression${NC} ${DIM}(e.g. 0 2 * * *): ${NC}"
                read -r cron_expr
                cron_label="Custom: ${cron_expr}"
                break
                ;;
            0) ui "  ${DIM}Skipped.${NC}"; return 0 ;;
            *) ui "  ${RED}Invalid choice. Try again.${NC}" ;;
        esac
    done

    local cron_line="${cron_expr} ${INSTALL_PATH} --run${delete_flag}${bg_flag}"

    ui
    ui "  ${DIM}Schedule:${NC}    ${WHITE}${cron_label}${NC}"
    ui "  ${DIM}Cron entry:${NC}  ${WHITE}${cron_line}${NC}"
    ui

    echo -ne "  ${CYAN}Add this entry to your crontab?${NC} [Y/n]: "
    read -r confirm
    if [[ "${confirm:-y}" =~ ^[Nn]$ ]]; then
        ui "  ${DIM}Skipped. To add manually, run: ${WHITE}crontab -e${NC}"
        return 0
    fi

    # Check for duplicate before adding
    if crontab -l 2>/dev/null | grep -qF "${INSTALL_PATH}"; then
        ui
        ui "  ${YELLOW}⚠${NC} An existing rcmv cron entry was found:"
        crontab -l 2>/dev/null | grep "${INSTALL_PATH}" | while IFS= read -r line; do
            ui "    ${GRAY}${line}${NC}"
        done
        ui
        echo -ne "  ${YELLOW}Replace existing entry?${NC} [y/N]: "
        read -r confirm
        if [[ "${confirm:-n}" =~ ^[Yy]$ ]]; then
            local tmp_cron
            tmp_cron=$(mktemp)
            crontab -l 2>/dev/null | grep -v "${INSTALL_PATH}" > "$tmp_cron" || true
            echo "$cron_line" >> "$tmp_cron"
            crontab "$tmp_cron"
            rm -f "$tmp_cron"
            ui "  ${GREEN}✓${NC} Cron entry replaced"
        else
            ui "  ${DIM}Existing entry kept.${NC}"
        fi
    else
        local tmp_cron
        tmp_cron=$(mktemp)
        crontab -l 2>/dev/null > "$tmp_cron" || true
        echo "$cron_line" >> "$tmp_cron"
        crontab "$tmp_cron"
        rm -f "$tmp_cron"
        ui "  ${GREEN}✓${NC} Cron entry added"
    fi
    ui
    ui "  ${DIM}View your crontab:${NC}  ${WHITE}crontab -l${NC}"
    ui "  ${DIM}Edit your crontab:${NC}  ${WHITE}crontab -e${NC}"
}

# ── Show Cron Management ─────────────────────────────────────────────────────────
manage_cron() {
    show_header "rcmv v${VERSION} — Cron Management"

    ui "${CYAN}Current rcmv cron entries:${NC}"
    ui
    local entries
    entries=$(crontab -l 2>/dev/null | grep "${INSTALL_PATH}" || true)
    if [[ -z "$entries" ]]; then
        ui "  ${DIM}No rcmv cron entries found.${NC}"
    else
        while IFS= read -r line; do
            ui "  ${WHITE}${line}${NC}"
        done <<< "$entries"
    fi
    ui

    show_section "Options"
    ui "  ${WHITE}[1]${NC} Add / replace schedule"
    ui "  ${WHITE}[2]${NC} Remove all rcmv cron entries"
    ui "  ${WHITE}[3]${NC} Open crontab in editor"
    ui "  ${WHITE}[0]${NC} Back"
    ui

    local choice
    echo -ne "  ${BOLD}Select${NC} ${DIM}[0-3]: ${NC}"
    read -r choice
    case "$choice" in
        1) setup_cron_wizard ;;
        2)
            echo -ne "  ${YELLOW}Remove all rcmv cron entries?${NC} [y/N]: "
            read -r confirm
            if [[ "${confirm:-n}" =~ ^[Yy]$ ]]; then
                local tmp_cron
                tmp_cron=$(mktemp)
                crontab -l 2>/dev/null | grep -v "${INSTALL_PATH}" > "$tmp_cron" || true
                crontab "$tmp_cron"
                rm -f "$tmp_cron"
                log_success "All rcmv cron entries removed"
            fi
            ;;
        3) crontab -e ;;
        0) return 0 ;;
        *) log_warning "Invalid choice" ;;
    esac
}

# ── Status ───────────────────────────────────────────────────────────────────────
show_status() {
    show_header "rcmv v${VERSION} — Status"

    show_section "Configuration"
    ui
    ui "  ${DIM}Source dir:       ${NC}${WHITE}${SOURCE_DIR:-<not set>}${NC}"
    ui "  ${DIM}Destination:      ${NC}${WHITE}${REMOTE:-<not set>}:${REMOTE_PATH}${NC}"
    ui "  ${DIM}Transfers:        ${NC}${WHITE}${TRANSFERS}${NC}"
    ui "  ${DIM}Checkers:         ${NC}${WHITE}${CHECKERS}${NC}"
    ui "  ${DIM}Buffer size:      ${NC}${WHITE}${BUFFER_SIZE}${NC}"
    ui "  ${DIM}Chunk size:       ${NC}${WHITE}${CHUNK_SIZE}${NC}"
    ui "  ${DIM}Bandwidth:        ${NC}${WHITE}${BWLIMIT:-unlimited}${NC}"
    ui "  ${DIM}Force overwrite:  ${NC}${WHITE}${FORCE_OVERWRITE}${NC}"
    ui "  ${DIM}Delete after:     ${NC}${WHITE}${DELETE_AFTER_UPLOAD}${NC}"
    ui "  ${DIM}Pushover:         ${NC}${WHITE}${NOTIFY_PUSHOVER}${NC}"
    ui "  ${DIM}ntfy:             ${NC}${WHITE}${NOTIFY_NTFY}${NC}"
    ui "  ${DIM}Config file:      ${NC}${WHITE}${CONFIG_FILE}${NC}"
    ui "  ${DIM}Log file:         ${NC}${WHITE}${LOG_FILE}${NC}"
    ui

    show_section "Cron"
    ui
    local cron_entries
    cron_entries=$(crontab -l 2>/dev/null | grep "${INSTALL_PATH}" || true)
    if [[ -n "$cron_entries" ]]; then
        while IFS= read -r line; do
            ui "  ${GREEN}✓${NC} ${WHITE}${line}${NC}"
        done <<< "$cron_entries"
    else
        ui "  ${DIM}No cron schedule set. Run: ${WHITE}rcmv --cron${NC}"
    fi
    ui

    show_section "Source"
    ui
    if [[ -z "$SOURCE_DIR" ]]; then
        ui "  ${RED}✗${NC} Source directory not configured"
        ui "  ${DIM}Run: ${WHITE}rcmv --setup${NC}"
    elif [[ -d "$SOURCE_DIR" ]]; then
        ui "  ${GREEN}✓${NC} Directory exists: ${WHITE}${SOURCE_DIR}${NC}"
        local movies_count=0 tv_count=0 total_size="unknown"
        [[ -d "${SOURCE_DIR}/movies" ]] && movies_count=$(find "${SOURCE_DIR}/movies" -maxdepth 1 -mindepth 1 -type d 2>/dev/null | wc -l)
        [[ -d "${SOURCE_DIR}/tv" ]]     && tv_count=$(find "${SOURCE_DIR}/tv" -maxdepth 1 -mindepth 1 -type d 2>/dev/null | wc -l)
        total_size=$(du -sh "$SOURCE_DIR" 2>/dev/null | awk '{print $1}')
        (( movies_count > 0 )) && ui "  ${DIM}Movies:${NC}  ${WHITE}${movies_count} titles${NC}"
        (( tv_count > 0 ))     && ui "  ${DIM}TV:${NC}      ${WHITE}${tv_count} shows${NC}"
        ui "  ${DIM}Total:${NC}   ${WHITE}${total_size}${NC}"
    else
        ui "  ${RED}✗${NC} Directory not found: ${WHITE}${SOURCE_DIR}${NC}"
    fi
    ui

    show_section "Remote"
    ui
    if [[ -z "$REMOTE" ]]; then
        ui "  ${RED}✗${NC} Remote not configured"
        ui "  ${DIM}Run: ${WHITE}rcmv --setup${NC}"
        return 0
    fi

    echo -ne "  ${DIM}Testing ${REMOTE}: connectivity...${NC} "
    if timeout 10 rclone lsd "${REMOTE}:" --max-depth 1 &>/dev/null 2>&1; then
        echo -e "${GREEN}✓ CONNECTED${NC}"
        echo -ne "  ${DIM}Checking ${REMOTE}:${REMOTE_PATH}...${NC}     "
        if rclone lsd "${REMOTE}:${REMOTE_PATH}" --max-depth 1 &>/dev/null 2>&1; then
            local remote_info
            remote_info=$(rclone size "${REMOTE}:${REMOTE_PATH}" 2>/dev/null \
                | grep "Total size" | sed 's/Total size: //' || echo "unknown")
            echo -e "${GREEN}✓ EXISTS${NC} ${DIM}(${remote_info})${NC}"
        else
            echo -e "${YELLOW}⚠ PATH NOT FOUND${NC} ${DIM}(will be created on first upload)${NC}"
        fi
    else
        echo -e "${RED}✗ UNREACHABLE${NC}"
        log_warning "Remote '${REMOTE}:' is not responding."
        ui "  ${DIM}Run ${WHITE}rclone listremotes${NC}${DIM} to verify remote names.${NC}"
    fi
    ui
}

# ── Validate Pre-flight ───────────────────────────────────────────────────────────
validate_preflight() {
    local errors=0

    if [[ -z "$SOURCE_DIR" ]]; then
        log_error "Source directory not configured. Run 'rcmv --setup'."
        (( errors++ )) || true
    elif [[ ! -d "$SOURCE_DIR" ]]; then
        log_error "Source directory not found: ${SOURCE_DIR}"
        (( errors++ )) || true
    fi

    if [[ -z "$REMOTE" ]]; then
        log_error "Remote not configured. Run 'rcmv --setup'."
        (( errors++ )) || true
    fi

    (( errors > 0 )) && return 1
    return 0
}

# ── Disk Stats Helper ─────────────────────────────────────────────────────────────
# Populates _DISK_USED, _DISK_TOTAL, _DISK_FREE, _DISK_PCT for $SOURCE_DIR device.
_DISK_USED="" _DISK_TOTAL="" _DISK_FREE="" _DISK_PCT=""
get_disk_stats() {
    local dir="${1:-$SOURCE_DIR}"
    if [[ ! -d "$dir" ]]; then
        _DISK_USED="N/A" _DISK_TOTAL="N/A" _DISK_FREE="N/A" _DISK_PCT="N/A"
        return
    fi
    local df_out
    df_out=$(df -BG "$dir" 2>/dev/null | tail -1) || {
        _DISK_USED="N/A" _DISK_TOTAL="N/A" _DISK_FREE="N/A" _DISK_PCT="N/A"
        return
    }
    _DISK_TOTAL=$(awk '{print $2}' <<< "$df_out")
    _DISK_USED=$(awk  '{print $3}' <<< "$df_out")
    _DISK_FREE=$(awk  '{print $4}' <<< "$df_out")
    _DISK_PCT=$(awk   '{print $5}' <<< "$df_out")
}

# ── Send Notification ─────────────────────────────────────────────────────────────
send_notification() {
    local title="$1"
    local body="$2"
    local success="${3:-true}"

    if [[ "$NOTIFY_PUSHOVER" == "true" && -n "$PUSHOVER_USER_KEY" && -n "$PUSHOVER_APP_TOKEN" ]]; then
        local priority=0
        [[ "$success" == "false" ]] && priority=1
        curl -s \
            --form-string "token=${PUSHOVER_APP_TOKEN}" \
            --form-string "user=${PUSHOVER_USER_KEY}" \
            --form-string "title=${title}" \
            --form-string "message=${body}" \
            --form-string "priority=${priority}" \
            "https://api.pushover.net/1/messages.json" \
            > /dev/null 2>&1 || log_warning "Pushover notification failed"
    fi

    if [[ "$NOTIFY_NTFY" == "true" && -n "$NTFY_URL" && -n "$NTFY_TOPIC" ]]; then
        local tags="white_check_mark"
        [[ "$success" == "false" ]] && tags="warning"
        curl -s \
            -H "Title: ${title}" \
            -H "Tags: ${tags}" \
            -d "$body" \
            "${NTFY_URL}/${NTFY_TOPIC}" \
            > /dev/null 2>&1 || log_warning "ntfy notification failed"
    fi
}

# ── Parse Rclone Stats from Log ──────────────────────────────────────────────────
# Rclone INFO log lines look like:
#   2006/01/02 15:04:05 INFO  : Transferred:        1.234 GiB / 1.234 GiB, 100%, ...
#   2006/01/02 15:04:05 INFO  : Transferred:               42 / 42, 100%
#   2006/01/02 15:04:05 INFO  : Checks:                   123 / 123, 100%
#   2006/01/02 15:04:05 INFO  : Errors:                     0
# We grab the LAST occurrence of each stat (final summary block).
_RCLONE_TRANSFERRED="" _RCLONE_CHECKS="" _RCLONE_ERRORS="" _RCLONE_FILES=""
parse_rclone_stats() {
    [[ ! -f "$LOG_FILE" ]] && return

    # Transferred bytes line — contains a size unit (KiB/MiB/GiB etc.)
    local t_line
    t_line=$(grep -aE 'Transferred:.*[0-9.]+ [KMGTPEZYkmgtpezy]?i?B' "$LOG_FILE" | tail -1)
    if [[ -n "$t_line" ]]; then
        _RCLONE_TRANSFERRED=$(echo "$t_line" \
            | grep -oE '[0-9.]+ [KMGTPEZYkmgtpezy]?i?B / [0-9.]+ [KMGTPEZYkmgtpezy]?i?B' \
            | head -1)
    fi
    [[ -z "$_RCLONE_TRANSFERRED" ]] && _RCLONE_TRANSFERRED="0 B / 0 B"

    # Files transferred line — "Transferred: N / N, 100%" (no size unit)
    local f_line
    f_line=$(grep -aE 'Transferred:[[:space:]]+[0-9]+ / [0-9]+' "$LOG_FILE" \
        | grep -v '[KMGTPEZYkmgtpezy]iB' | tail -1)
    if [[ -n "$f_line" ]]; then
        _RCLONE_FILES=$(echo "$f_line" | grep -oE '[0-9]+' | head -1)
    fi
    [[ -z "$_RCLONE_FILES" ]] && _RCLONE_FILES="0"

    # Errors
    local e_line
    e_line=$(grep -aE 'Errors:[[:space:]]+[0-9]+' "$LOG_FILE" | tail -1)
    [[ -n "$e_line" ]] && _RCLONE_ERRORS=$(echo "$e_line" | grep -oE '[0-9]+' | head -1)
    [[ -z "$_RCLONE_ERRORS" ]] && _RCLONE_ERRORS="0"

    # Checks
    local c_line
    c_line=$(grep -aE 'Checks:[[:space:]]+[0-9]+' "$LOG_FILE" | tail -1)
    [[ -n "$c_line" ]] && _RCLONE_CHECKS=$(echo "$c_line" | grep -oE '[0-9]+' | head -1)
    [[ -z "$_RCLONE_CHECKS" ]] && _RCLONE_CHECKS="0"
}

# ── Remote Size ──────────────────────────────────────────────────────────────────
_REMOTE_SIZE=""
get_remote_size() {
    _REMOTE_SIZE=$(rclone size "${REMOTE}:${REMOTE_PATH}" 2>/dev/null \
        | grep "Total size" | sed 's/.*Total size: //' || echo "unknown")
}

# ── Build Report ─────────────────────────────────────────────────────────────────
build_report() {
    local elapsed_fmt="$1"
    local upload_ok="$2"
    local disk_before_used="$3"   disk_before_total="$4"
    local disk_before_free="$5"   disk_before_pct="$6"
    local disk_after_used="$7"    disk_after_total="$8"
    local disk_after_free="$9"    disk_after_pct="${10}"

    local date_str
    date_str=$(date '+%A, %B %-d %Y · %H:%M' 2>/dev/null || date '+%Y-%m-%d %H:%M')

    local status_line op_word
    if [[ "$DELETE_AFTER_UPLOAD" == "true" ]]; then
        op_word="Moved"
    else
        op_word="Uploaded"
    fi

    if [[ "$upload_ok" == "true" ]]; then
        status_line="✓ Completed in ${elapsed_fmt}"
    else
        status_line="✗ Failed after ${elapsed_fmt}"
    fi

    cat << EOF
🌀 RCMV Report
${date_str}

📦 Transfer Info:
${status_line}
Files ${op_word}: ${_RCLONE_FILES:-0}
Transferred: ${_RCLONE_TRANSFERRED:-0 B / 0 B}
Checks: ${_RCLONE_CHECKS:-0} · Errors: ${_RCLONE_ERRORS:-0}

📊 Remote:
Remote: ${REMOTE}
Directory: ${REMOTE_PATH}
Remote Size: ${_REMOTE_SIZE:-unknown}

💾 Local Disk (${SOURCE_DIR}):
Before: ${disk_before_used} / ${disk_before_total} (${disk_before_pct} used) · Free: ${disk_before_free}
After:  ${disk_after_used} / ${disk_after_total} (${disk_after_pct} used) · Free: ${disk_after_free}
EOF
}

# ── Build Rclone Command ──────────────────────────────────────────────────────────
# Uses 'rclone move' when DELETE_AFTER_UPLOAD=true — rclone deletes each local file
# only after it has been successfully uploaded and verified on the remote.
# Uses 'rclone copy' otherwise (local files untouched).
build_rclone_cmd() {
    local dry_run="${1:-false}"
    local force="${2:-$FORCE_OVERWRITE}"

    local subcmd="copy"
    [[ "$DELETE_AFTER_UPLOAD" == "true" ]] && subcmd="move"

    local -a cmd=(
        rclone "$subcmd"
        "$SOURCE_DIR"
        "${REMOTE}:${REMOTE_PATH}"
        --transfers "$TRANSFERS"
        --checkers "$CHECKERS"
        --multi-thread-streams "$MULTI_THREAD_STREAMS"
        --buffer-size "$BUFFER_SIZE"
        --drive-chunk-size "$CHUNK_SIZE"
        --drive-upload-cutoff "$CHUNK_SIZE"
        --cutoff-mode hard
        --order-by size,desc
        --no-traverse
        --fast-list
        --delete-empty-src-dirs
        --log-level NOTICE
        --log-file "$LOG_FILE"
    )

    # --progress only makes sense when attached to a terminal
    if $TERMINAL && ! $BACKGROUND; then
        cmd+=(--progress)
    fi

    [[ -n "$BWLIMIT" ]] && cmd+=(--bwlimit "$BWLIMIT")

    if [[ "$force" == "true" ]]; then
        cmd+=(--ignore-checksum --ignore-times)
    fi

    [[ "$dry_run" == "true" ]] && cmd+=(--dry-run)

    printf '%q ' "${cmd[@]}"
}

# ── Dry Run ───────────────────────────────────────────────────────────────────────
run_dry() {
    local force="${1:-$FORCE_OVERWRITE}"

    show_header "rcmv v${VERSION} — Dry Run"
    validate_preflight || return 1

    ui "${CYAN}Simulating upload — no files will be transferred.${NC}"
    ui
    ui "  ${DIM}Source:${NC}       ${WHITE}${SOURCE_DIR}${NC}"
    ui "  ${DIM}Destination:${NC}  ${WHITE}${REMOTE}:${REMOTE_PATH}${NC}"
    [[ "$force" == "true" ]] && ui "  ${YELLOW}⚠${NC}  Force overwrite active"
    [[ "$DELETE_AFTER_UPLOAD" == "true" ]] && \
        ui "  ${RED}⚠${NC}  ${RED}Delete after upload is ON — run without --dry-run to delete${NC}"
    ui

    local cmd_str
    cmd_str="$(build_rclone_cmd true "$force")"
    ui "${GRAY}▶ ${cmd_str}${NC}"
    ui

    eval "$cmd_str"
    local exit_code=$?

    ui
    if [[ $exit_code -eq 0 ]]; then
        result_box true "Dry run complete"
    else
        result_box false "Dry run encountered errors (exit ${exit_code})"
    fi
    return $exit_code
}

# ── Upload ────────────────────────────────────────────────────────────────────────
run_upload() {
    local force="${1:-$FORCE_OVERWRITE}"

    show_header "rcmv v${VERSION} — Upload"
    validate_preflight || return 1
    mkdir -p "$(dirname "$LOG_FILE")"

    ui "  ${DIM}Source:${NC}       ${WHITE}${SOURCE_DIR}${NC}"
    ui "  ${DIM}Destination:${NC}  ${WHITE}${REMOTE}:${REMOTE_PATH}${NC}"
    ui "  ${DIM}Log:${NC}          ${WHITE}${LOG_FILE}${NC}"
    [[ "$force" == "true" ]] && \
        ui "  ${YELLOW}⚠${NC}  Force overwrite — cloud files will be replaced by local"
    if [[ "$DELETE_AFTER_UPLOAD" == "true" ]]; then
        ui
        ui "  ${RED}${BOLD}⚠ MOVE MODE — rclone move is active${NC}"
        ui "  ${RED}Each file is deleted from local storage after a confirmed upload.${NC}"
    fi
    ui

    # Interactive confirmation — skipped in background mode
    if ! $BACKGROUND; then
        echo -ne "  ${CYAN}Start upload?${NC} [Y/n]: "
        read -r confirm
        if [[ "${confirm:-y}" =~ ^[Nn]$ ]]; then
            ui "${DIM}Upload cancelled.${NC}"
            return 0
        fi
        ui
    fi

    # Capture disk stats before upload
    get_disk_stats "$SOURCE_DIR"
    local disk_before_used="$_DISK_USED"   disk_before_total="$_DISK_TOTAL"
    local disk_before_free="$_DISK_FREE"   disk_before_pct="$_DISK_PCT"

    local cmd_str
    cmd_str="$(build_rclone_cmd false "$force")"
    ui "${GRAY}▶ ${cmd_str}${NC}"
    ui

    local start_time=$SECONDS
    eval "$cmd_str"
    local exit_code=$?
    local elapsed=$(( SECONDS - start_time ))
    local elapsed_fmt
    elapsed_fmt="$(( elapsed / 60 ))m $(( elapsed % 60 ))s"

    local upload_ok="true"
    [[ $exit_code -ne 0 ]] && upload_ok="false"

    local op_label="Upload"
    [[ "$DELETE_AFTER_UPLOAD" == "true" ]] && op_label="Move"

    ui
    if [[ "$upload_ok" == "true" ]]; then
        result_box true "${op_label} complete in ${elapsed_fmt}"
        log_success "${op_label} finished in ${elapsed_fmt} — log: ${LOG_FILE}"
    else
        result_box false "${op_label} failed (exit ${exit_code})"
        log_error "${op_label} failed (exit ${exit_code}) — log: ${LOG_FILE}"
    fi

    # Capture disk stats after upload/delete
    get_disk_stats "$SOURCE_DIR"
    local disk_after_used="$_DISK_USED"   disk_after_total="$_DISK_TOTAL"
    local disk_after_free="$_DISK_FREE"   disk_after_pct="$_DISK_PCT"

    # Parse rclone stats from log
    parse_rclone_stats

    # Remote size
    get_remote_size

    # Build and send notification report
    if [[ "$NOTIFY_PUSHOVER" == "true" || "$NOTIFY_NTFY" == "true" ]]; then
        local report
        report=$(build_report \
            "$elapsed_fmt" "$upload_ok" \
            "$disk_before_used" "$disk_before_total" \
            "$disk_before_free" "$disk_before_pct" \
            "$disk_after_used"  "$disk_after_total" \
            "$disk_after_free"  "$disk_after_pct")

        send_notification "🌀 RCMV Report" "$report" "$upload_ok"
        log_info "Notification sent"
    fi

    return $exit_code
}

# ── View Logs ─────────────────────────────────────────────────────────────────────
view_logs() {
    local mode="${1:-tail}" lines="${2:-50}"

    if [[ ! -f "$LOG_FILE" ]]; then
        log_error "Log file not found: ${LOG_FILE}"
        log_info  "It will be created on first upload."
        return 1
    fi

    case "$mode" in
        --tail|--follow|-t)
            ui "${CYAN}Following log (Ctrl+C to exit)...${NC}"
            tail -f -n "$lines" "$LOG_FILE"
            ;;
        --errors|-e)
            ui "${CYAN}Errors and warnings:${NC}"
            grep -iE "error|failed|panic|warn" "$LOG_FILE" | tail -n "$lines"
            ;;
        --full)
            less +G "$LOG_FILE"
            ;;
        *)
            tail -n "$lines" "$LOG_FILE"
            ;;
    esac
}

# ── Bandwidth ─────────────────────────────────────────────────────────────────────
set_bandwidth() {
    if [[ $# -eq 0 ]]; then
        ui "${CYAN}Current bandwidth limit:${NC} ${WHITE}${BWLIMIT:-unlimited}${NC}"
        ui
        ui "Usage: rcmv --bwlimit <speed>"
        ui "  ${WHITE}rcmv --bwlimit 10M${NC}   # 10 MB/s"
        ui "  ${WHITE}rcmv --bwlimit 512K${NC}  # 512 KB/s"
        ui "  ${WHITE}rcmv --bwlimit off${NC}   # No limit"
        return 0
    fi

    local new_limit="$1"
    if [[ "$new_limit" == "off" || "$new_limit" == "unlimited" ]]; then
        BWLIMIT=""
        log_success "Bandwidth limit removed"
    else
        BWLIMIT="$new_limit"
        log_success "Bandwidth limit set to: ${BWLIMIT}"
    fi
    save_config
}

# ── Install ───────────────────────────────────────────────────────────────────────
install_script() {
    show_header "rcmv v${VERSION} — Install"

    local script_src
    script_src="$(realpath "$0")"

    ui "  ${DIM}Source:${NC}  ${WHITE}${script_src}${NC}"
    ui "  ${DIM}Target:${NC}  ${WHITE}${INSTALL_PATH}${NC}"
    ui

    echo -ne "  ${DIM}Copying to ${INSTALL_PATH}...${NC} "
    if sudo cp "$script_src" "$INSTALL_PATH" && sudo chmod +x "$INSTALL_PATH"; then
        echo -e "${GREEN}✓${NC}"
    else
        echo -e "${RED}✗${NC}"
        die "Failed to install to ${INSTALL_PATH} — check sudo permissions"
    fi

    local shell_name rc_file
    shell_name="$(basename "${SHELL:-bash}")"
    case "$shell_name" in
        zsh)  rc_file="$HOME/.zshrc" ;;
        bash) rc_file="$HOME/.bashrc" ;;
        *)    rc_file="$HOME/.bashrc" ;;
    esac

    echo -ne "  ${DIM}Adding alias to ${rc_file}...${NC} "
    if grep -q "alias ${SCRIPT_NAME}=" "$rc_file" 2>/dev/null; then
        echo -e "${YELLOW}⚠ alias already present (skipped)${NC}"
    else
        {
            echo ""
            echo "# rcmv — rclone media upload manager"
            echo "alias ${SCRIPT_NAME}='${INSTALL_PATH}'"
        } >> "$rc_file"
        echo -e "${GREEN}✓${NC}"
    fi

    ui
    result_box true "${SCRIPT_NAME} installed"
    ui
    ui "${CYAN}Reload your shell:${NC}  ${WHITE}source ${rc_file}${NC}"
    ui "${CYAN}First-time setup:${NC}   ${WHITE}rcmv --setup${NC}"
    ui
}

# ── Uninstall ─────────────────────────────────────────────────────────────────────
uninstall_script() {
    show_header "rcmv v${VERSION} — Uninstall"

    echo -ne "  ${DIM}Removing ${INSTALL_PATH}...${NC} "
    if [[ -f "$INSTALL_PATH" ]]; then
        if sudo rm -f "$INSTALL_PATH"; then
            echo -e "${GREEN}✓${NC}"
        else
            echo -e "${RED}✗${NC}"
            die "Failed to remove ${INSTALL_PATH} — check sudo permissions"
        fi
    else
        echo -e "${YELLOW}⚠ not found (skipped)${NC}"
    fi

    for rc_file in "$HOME/.zshrc" "$HOME/.bashrc"; do
        [[ ! -f "$rc_file" ]] && continue
        if grep -q "alias ${SCRIPT_NAME}=" "$rc_file" 2>/dev/null; then
            echo -ne "  ${DIM}Removing alias from ${rc_file}...${NC} "
            sed -i "/# rcmv — rclone media upload manager/d;/alias ${SCRIPT_NAME}=/d" "$rc_file"
            echo -e "${GREEN}✓${NC}"
        fi
    done

    # Remove cron entries
    if crontab -l 2>/dev/null | grep -q "${INSTALL_PATH}"; then
        echo -ne "  ${DIM}Removing cron entries...${NC} "
        local tmp_cron
        tmp_cron=$(mktemp)
        crontab -l 2>/dev/null | grep -v "${INSTALL_PATH}" > "$tmp_cron" || true
        crontab "$tmp_cron"
        rm -f "$tmp_cron"
        echo -e "${GREEN}✓${NC}"
    fi

    ui
    echo -ne "  ${YELLOW}Remove config and logs too?${NC} [y/N]: "
    read -r confirm
    if [[ "${confirm:-n}" =~ ^[Yy]$ ]]; then
        rm -rf "$HOME/.config/rcmv"      && log_success "Config removed"
        rm -rf "$HOME/.local/share/rcmv" && log_success "Logs removed"
    fi

    ui
    result_box true "${SCRIPT_NAME} uninstalled"
}

