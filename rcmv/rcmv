    ui "  Delete after:   ${WHITE}${DELETE_AFTER_UPLOAD}${NC}"
    ui "  Pushover:       ${WHITE}${NOTIFY_PUSHOVER}${NC}"
    ui "  ntfy:           ${WHITE}${NOTIFY_NTFY}${NC}"
    ui "  Config:         ${WHITE}${CONFIG_FILE}${NC}"
    ui "  Log:            ${WHITE}${LOG_FILE}${NC}"
    ui

    show_section "Examples"
    ui "  rcmv --setup"
    ui "  rcmv --dry-run"
